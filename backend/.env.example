# App
APP_NAME=PromptIO
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-min-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o
OPENROUTER_SITE_URL=https://promptio.app
OPENROUTER_SITE_NAME=PromptIO

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# JWT
JWT_SECRET_KEY=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=promptio-assets

# Security
RATE_LIMIT_PER_MINUTE=60
MAX_PROMPT_LENGTH=50000
ALLOWED_ORIGINS=http://localhost:3000,https://promptio.app

# Compliance
GDPR_MODE=true
DATA_RETENTION_DAYS=365
AUDIT_LOG_ENABLED=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2